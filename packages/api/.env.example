# Supabase PostgreSQL 数据库
# 格式：postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres
# 开发环境通过 SOCKS5 隧道连接：127.0.0.1:5433
DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres"

# JWT 密钥（请换为你自己的随机字符串）
JWT_SECRET="your-super-secret-key-change-in-production"

# 允许的跨域来源（逗号分隔，生产环境必填）
# 开发环境不配此项则默认允许 localhost:3000/3001
# 示例：ALLOWED_ORIGINS=https://shiguangjian.app,https://www.shiguangjian.app
ALLOWED_ORIGINS=""

# Server酱推送（可选）
SERVERCHAN_KEY="your-serverchan-sendkey"

# Firebase FCM 推送（可选）
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="your-private-key"

# 服务器
PORT=3000
HOST=0.0.0.0
